---
const skillCategories = [
  {
    title: 'Frontend Development',
    icon: 'fas fa-code',
    skills: [
      { name: 'HTML', icon: 'fab fa-html5' },
      { name: 'CSS', icon: 'fab fa-css3-alt' },
      { name: 'JavaScript', icon: 'fab fa-js' },
      { name: 'React', icon: 'fab fa-react' }
    ]
  },
  {
    title: 'Backend Development',
    icon: 'fas fa-server',
    skills: [
      { name: 'Node.js', icon: 'fab fa-node-js' },
      { name: 'Express.js', icon: 'fas fa-cogs' },
      { name: 'MySQL', icon: 'fas fa-database' },
      { name: 'MongoDB', icon: 'fas fa-database' }
    ]
  },
  {
    title: 'Other Tools',
    icon: 'fas fa-tools',
    skills: [
      { name: 'Git', icon: 'fab fa-git-alt' },
      { name: 'GitHub', icon: 'fab fa-github' },
      { name: 'Version Control', icon: 'fas fa-code-branch' },
      { name: 'Cloud Services', icon: 'fas fa-cloud' }
    ]
  }
];
---
<section id="skills" class="py-24 bg-neutral-950 transition-colors duration-200">
  <div class="container mx-auto px-4 lg:px-8 max-w-6xl">
    <div class="mb-16 text-center">
      <h2 class="text-3xl font-bold tracking-tight text-neutral-200 mb-4">
        Skills & Technologies
      </h2>
      <p class="text-lg text-neutral-400 max-w-2xl mx-auto">
        Here are some of the technologies and tools I work with regularly.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {skillCategories.map((category) => (
        <div class="group relative overflow-hidden bg-neutral-950 rounded-xl p-8 border border-neutral-800 hover:border-neutral-700 transition duration-300">
          <!-- Background watermark icon -->
          <i class={`${category.icon} absolute -bottom-6 -right-6 text-[8rem] leading-none text-neutral-900 group-hover:text-neutral-800/80 transition-colors duration-500 pointer-events-none select-none`} aria-hidden="true"></i>

          <!-- Corner ribbon badge -->
          <div class="absolute top-0 right-0 w-28 h-28 overflow-hidden pointer-events-none">
            <span class="absolute top-[18px] right-[-32px] w-[140px] rotate-45 bg-emerald-500 text-center text-[10px] font-bold uppercase tracking-wider text-neutral-950 py-1">
              {category.skills.length} Skills
            </span>
          </div>

          <div class="relative text-2xl text-neutral-500 mb-6 flex items-center justify-center">
            <i class={category.icon}></i>
          </div>
          <h3 class="relative text-lg font-semibold text-center text-neutral-200 mb-6">
            {category.title}
          </h3>
          <ul class="relative space-y-4">
            {category.skills.map((skill) => (
              <li class="text-neutral-400 flex items-center justify-center space-x-3 group/skill transition-colors duration-200 hover:text-neutral-200">
                <i class={`${skill.icon} text-neutral-500 group-hover/skill:text-neutral-300 transition-colors`}></i>
                <span class="text-sm font-medium">{skill.name}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
