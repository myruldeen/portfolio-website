---
const skillCategories = [
  {
    title: 'Frontend Development',
    icon: 'fas fa-code',
    skills: [
      { name: 'HTML' },
      { name: 'CSS' },
      { name: 'JavaScript' },
      { name: 'React' }
    ]
  },
  {
    title: 'Backend Development',
    icon: 'fas fa-server',
    skills: [
      { name: 'Node.js' },
      { name: 'Express.js' },
      { name: 'MySQL' },
      { name: 'MongoDB' }
    ]
  },
  {
    title: 'Other Tools',
    icon: 'fas fa-tools',
    skills: [
      { name: 'Git' },
      { name: 'GitHub' },
      { name: 'Version Control' },
      { name: 'Cloud Services' }
    ]
  }
];
---
<section id="skills" class="py-24 bg-neutral-950 transition-colors duration-200">
  <div class="container mx-auto px-4 lg:px-8 max-w-6xl">
    <div class="mb-16">
      <p class="text-xs font-bold uppercase tracking-widest text-emerald-500 mb-3">Toolbox</p>
      <h2 class="font-display text-3xl font-bold tracking-tight text-neutral-100 mb-4">
        The stack I work with
      </h2>
      <p class="text-lg text-neutral-400 max-w-2xl">
        I pick tools that fit the problem. Here's what I reach for most.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-10">
      {skillCategories.map((category) => (
        <div>
          <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-neutral-800">
            <i class={`${category.icon} text-emerald-500 text-sm`}></i>
            <p class="text-xs font-bold uppercase tracking-widest text-neutral-500">{category.title}</p>
          </div>
          <div class="flex flex-wrap gap-2">
            {category.skills.map((skill) => (
              <span class="px-3 py-1.5 text-sm text-neutral-300 bg-neutral-900 border border-neutral-800 rounded-full hover:border-neutral-700 hover:text-neutral-100 transition duration-300">
                {skill.name}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
